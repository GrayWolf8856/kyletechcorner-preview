(global_label "SOIL_ADC" (shape bidirectional) (at 71.12 91.44 180) (fields_autoplaced yes)
  (effects (font (size 1.27 1.27)) (justify left))
  (uuid "dfaf27b4-e898-53e7-828b-c60765d68137"))
(text "PUMP LOGIC: Q3 (2N7000) inverts. Relay module IN is active-LOW, so" (exclude_from_sim no) (at 149.86 121.92 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "c66ed800-5c0e-54cf-a8eb-6659702277fb"))
(text "digitalWrite(GPIO7, HIGH) = relay energized = PUMP ON. Keep the inverter." (exclude_from_sim no) (at 149.86 124.46 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "be78800e-d900-502b-9ca3-d04cceb6b09f"))
(text "J5 wiring: J5.1 (+5V) -> relay module COM screw. Relay NO screw -> J5.2." (exclude_from_sim no) (at 149.86 129.54 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "e17b032b-b687-5acd-99ad-a5efae36fc40"))
(text "Pump then connects at J3 (1 = +, 2 = GND)." (exclude_from_sim no) (at 149.86 132.08 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "13b4b91c-2cf0-5d8f-bc02-2bc2113797b4"))
(text "SOIL SENSOR: J4 supplies 3.3V ONLY. GPIO0 = ADC1, WiFi-safe." (exclude_from_sim no) (at 50.8 121.92 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "4af6685e-3eb2-5641-8a62-60139e6fb5e8"))
(text "PIN MAP: WHITE=GPIO6  PUMP=GPIO7  GROW=GPIO10  SOIL=GPIO0" (exclude_from_sim no) (at 50.8 124.46 0)
  (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid "23bca346-4faa-5347-9cc5-7de93c2d6fb0"))
